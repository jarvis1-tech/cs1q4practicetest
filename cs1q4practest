        "def number_evaluator():\n",
        "  print(\"Welcome to the Simple Number Evaluator!\")\n",
        "\n",
        "  num_numbers = 0\n",
        "  while num_numbers < 1:\n",
        "    try:\n",
        "      num_numbers = int(input(\"How many numbers do you want to enter?\"))\n",
        "      if num_numbers < 1:\n",
        "        print(\"Please enter a number greater than zero.\")\n",
        "    except ValueError:\n",
        "      print(\"That's not a whole number.\")\n",
        "  total = 0\n",
        "  print(f\"Let's enter {num_numbers} numbers.\")\n",
        "  for i in range(num_numbers):\n",
        "    number = 0\n",
        "    while True:\n",
        "      try:\n",
        "        number = int(input(f\"Enter number {i + 1}: \"))\n",
        "        break\n",
        "      except ValueError:\n",
        "        print(\"That's not a whole number. Please try again.\")\n",
        "    if number % 2 == 0:\n",
        "      print(f\"{number} is an even number.\")\n",
        "    else:\n",
        "      print(f\"{number} is an odd number.\")\n",
        "    total += number\n",
        "  print(\"Results:\")\n",
        "  print(f\"The sum of all your numbers is: {total}\")\n",
        "\n",
        "  if num_numbers > 0:\n",
        "    average = total / num_numbers\n",
        "    print(f\"The average of all your numbers is: {average:.2f}\")\n",
        "  else:\n",
        "    print(\"ERROR: No numbers were entered\")\n",
        "number_evaluator()"
      ],
